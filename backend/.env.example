PORT=4000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_reporting
DB_USER=root
DB_PASSWORD=your_mysql_root_password
# Set to "true" only for the one server restart right after you change a
# model file, so Sequelize can add the new column/index. Leave unset (or
# "false") the rest of the time - running alter-sync on every nodemon
# restart is what causes MySQL's "Too many keys specified" error.
DB_SYNC_ALTER=false
JWT_SECRET=change_me_to_a_long_random_string
# How long a login session lasts before the person is forced back to the
# login screen automatically. The app has no idle/inactivity timer of its
# own — a session only ends when the person clicks "Logout" (which works
# immediately, server-side) OR when this much time has passed since they
# logged in, whichever comes first. Default is long (30 days) so that in
# practice, logging out is what ends a session, not a timer.
# Examples: "12h", "1d", "7d", "30d". If sessions are ending sooner than you
# expect, this is almost always the cause — check the value actually set in
# your real .env file (this example file is not read at runtime).
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=7d
SUPERUSER_EMAIL=superuser@platform.com
SUPERUSER_PASSWORD=ChangeMe123!

# Used to build the link inside the "forgot password" email (superuser only).
# Point this at wherever the frontend is actually served.
FRONTEND_URL=http://localhost:5173

# SMTP settings for sending the superuser password-reset email. If SMTP_HOST
# is left unset, the reset link is logged to the backend console instead of
# emailed — handy for local development, not for production.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mid-Term Reporting System <no-reply@example.com>"
